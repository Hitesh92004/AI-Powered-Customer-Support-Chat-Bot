# Neon PostgreSQL (get from neon.tech dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Groq API (console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile


# JWT Auth (generate a long random string)
JWT_SECRET_KEY=your-very-long-random-secret-key-at-least-32-chars
JWT_EXPIRE_MINUTES=10080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Disable all user-uploaded files (recommended for FAQ-only mode)
ENABLE_USER_FILE_UPLOADS=false

# Server-side FAQ dataset used by /api/faq/train-dataset
FAQ_DATASET_PATH=backend/data/faq_dataset.json

# Optional sklearn intent router (set true after training model artifact)
ENABLE_INTENT_ROUTER=false
INTENT_MODEL_PATH=backend/models/intent_router.joblib
INTENT_CONFIDENCE_THRESHOLD=0.65
